{
  "name": "taskflow-ai-backend",
  "version": "2.0.0",
  "private": true,
  "description": "TaskFlow AI backend API",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "node_modules\\.bin\\prisma.cmd generate && node_modules\\.bin\\prisma.cmd migrate deploy",
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "postinstall": "npx prisma generate",
    "test": "jest --runInBand",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:push": "npx prisma db push",
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "tasks",
    "jwt",
    "rbac",
    "ai",
    "dashboard"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "prisma": "^7.5.0",
    "redis": "^5.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
